# Zenith Account Server Configuration
# Copy this file to .env and update with your production values
#
# Usage:
#   source .env && ./run-production.sh
# or
#   export $(cat .env | xargs) && docker-compose up -d

# Server hostname/IP to bind to
# Use 0.0.0.0 to listen on all interfaces
# Use 127.0.0.1 for localhost only (behind reverse proxy)
ZENITH_HOST=0.0.0.0

# Server port
ZENITH_PORT=3000

# JWT signing secret - MUST be set in production!
# Generate with: openssl rand -base64 32
ZENITH_JWT_SECRET=zenith-super-secret-key-change-in-production

# SQLite database path
# Local: zenith_accounts.db
# Production: /var/lib/zenith/accounts.db
ZENITH_DB_PATH=zenith_accounts.db
